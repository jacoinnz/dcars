# Neon — copy connection string from: Dashboard → your project → Connect → .env
# Format: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# Vercel may also expose POSTGRES_URL / POSTGRES_PRISMA_URL; the app accepts those too.
DATABASE_URL=

# NextAuth — generate a long random string for AUTH_SECRET (e.g. openssl rand -base64 32)
AUTH_SECRET=
# Public URL of this app (production: https://your-domain.vercel.app)
NEXTAUTH_URL=http://localhost:3000

# Optional: Vercel Blob for teacher file uploads (larger files). Without it, files store in Postgres (2MB cap).
# BLOB_READ_WRITE_TOKEN=
