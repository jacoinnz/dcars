# Neon — copy connection string from: Dashboard → your project → Connect → .env
# Format: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# Vercel may also expose POSTGRES_URL / POSTGRES_PRISMA_URL; the app accepts those too.
DATABASE_URL=

# NextAuth — required for login and protected routes
# Generate secret: openssl rand -base64 32
# On Vercel (Production + Preview): set AUTH_SECRET (or NEXTAUTH_SECRET) or you get NO_SECRET / 500 on /api/auth/*
AUTH_SECRET=
# Public origin of this app (no trailing slash). Local dev:
NEXTAUTH_URL=http://localhost:3000
# Production: https://your-app.vercel.app — must match the deployment URL or OAuth/callbacks break

# Dev/smoke only: bypass login and middleware protection. Never set SKIP_AUTH=true in production.
# SKIP_AUTH=true
# Optional: real app_users.id UUID so site permissions match a user (defaults to a placeholder UUID).
# SKIP_AUTH_USER_ID=
# SKIP_AUTH_EMAIL=skip-auth@localhost
# SKIP_AUTH_SUPER_ADMIN=true

# Optional: Vercel Blob for teacher file uploads (larger files). Without it, files store in Postgres (2MB cap).
# BLOB_READ_WRITE_TOKEN=
